@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-center mb-3">ReleaseHub</h3>
                <p class="text-muted text-center">
                    Sign in with your corporate SSO account.
                </p>

                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                @if (!string.IsNullOrEmpty(Model.SsoLoginUrl))
                {
                    <a class="btn btn-primary w-100 mb-3" href="@Model.SsoLoginUrl" target="_blank" rel="noopener">
                        Open SSO login &raquo;
                    </a>
                    <p class="text-muted small">
                        After SSO returns the access token, paste it below and submit.
                    </p>
                }

                <form method="post" asp-controller="Account" asp-action="Login"
                      asp-route-returnUrl="@(ViewData["ReturnUrl"] as string)">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="AccessToken">SSO access token</label>
                        <textarea id="AccessToken" name="AccessToken" rows="3" class="form-control"
                                  placeholder="Paste the token returned by SSO"></textarea>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Sign in</button>
                </form>
            </div>
        </div>
    </div>
</div>

@{
    var displayName = User?.Identity?.IsAuthenticated == true ? (User.Identity!.Name ?? "") : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReleaseHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="ReleaseTasks" asp-action="Index">ReleaseHub</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ReleaseTasks" asp-action="Index">Release Tasks</a>
                        </li>
                    }
                </ul>
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text text-light me-3">@displayName</span>
                    <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </div>
    </nav>
    <main class="container">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
